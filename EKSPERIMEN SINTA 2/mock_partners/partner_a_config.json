{
  "partner": "partner_a",
  "partner_name": "Partner A \u2014 Flat JSON snake_case",
  "base_url": "http://localhost:9001",
  "endpoint": "/shipment/create",
  "method": "POST",
  "description": "Flat JSON, snake_case, basic validation",
  "mapping_rules": [
    {
      "source": "order_id",
      "target": "order_id",
      "type": "string",
      "required": true,
      "min_length": 3
    },
    {
      "source": "customer_name",
      "target": "customer_name",
      "type": "string",
      "required": true,
      "min_length": 2
    },
    {
      "source": "customer_phone",
      "target": "customer_phone",
      "type": "string",
      "required": true,
      "validate_phone": true,
      "transform": "normalize_phone"
    },
    {
      "source": "address",
      "target": "delivery_address",
      "type": "string",
      "required": true
    },
    {
      "source": "weight",
      "target": "weight_kg",
      "type": "number",
      "required": true,
      "min_value": 0.01,
      "max_value": 1000
    },
    {
      "source": "created_at",
      "target": "order_date",
      "type": "date",
      "required": true,
      "validate_date": true
    },
    {
      "source": "courier",
      "target": "courier_code",
      "type": "string",
      "required": false,
      "enum": [
        "jne",
        "pos",
        "tiki",
        "jnt",
        "sicepat",
        "anteraja",
        "lion_parcel"
      ]
    },
    {
      "source": "item_name",
      "target": "item_name",
      "type": "string",
      "required": false
    },
    {
      "source": "quantity",
      "target": "quantity",
      "type": "integer",
      "required": false,
      "min_value": 1
    },
    {
      "source": "price",
      "target": "total_price",
      "type": "number",
      "required": false,
      "min_value": 0
    },
    {
      "source": "notes",
      "target": "notes",
      "type": "string",
      "required": false
    }
  ]
}