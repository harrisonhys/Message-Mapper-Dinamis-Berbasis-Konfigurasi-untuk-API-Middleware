{
  "partner": "partner_c",
  "partner_name": "Partner C — Nested JSON",
  "base_url": "http://localhost:9003",
  "endpoint": "/api/v1/delivery",
  "method": "POST",
  "description": "Partner C menggunakan nested JSON dengan objek bertingkat.",
  "mapping_rules": [
    {
      "source": "order_id",
      "target": "reference_no",
      "type": "string",
      "required": true
    },
    {
      "source": "customer_name",
      "target": "recipient.name",
      "type": "string",
      "required": true
    },
    {
      "source": "customer_phone",
      "target": "recipient.phone",
      "type": "string",
      "required": true,
      "transform": "normalize_phone"
    },
    {
      "source": "address",
      "target": "recipient.address",
      "type": "string",
      "required": true
    },
    {
      "source": "weight",
      "target": "package.weight_gram",
      "type": "number",
      "required": true,
      "transform": "kg_to_gram"
    },
    {
      "source": "created_at",
      "target": "order_date",
      "type": "date",
      "required": true,
      "transform": "yyyy_mm_dd_to_dd_mm_yyyy"
    },
    {
      "source": "item_name",
      "target": "package.item_description",
      "type": "string",
      "required": false
    },
    {
      "source": "quantity",
      "target": "package.quantity",
      "type": "number",
      "required": false
    },
    {
      "source": "price",
      "target": "package.declared_value",
      "type": "number",
      "required": false
    },
    {
      "source": "notes",
      "target": "recipient.notes",
      "type": "string",
      "required": false
    }
  ]
}
