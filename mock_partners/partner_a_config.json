{
  "partner": "partner_a",
  "partner_name": "Partner A — Flat JSON snake_case",
  "base_url": "http://localhost:9001",
  "endpoint": "/shipment/create",
  "method": "POST",
  "description": "Partner A menggunakan flat JSON dengan konvensi snake_case.",
  "mapping_rules": [
    {
      "source": "order_id",
      "target": "order_id",
      "type": "string",
      "required": true
    },
    {
      "source": "customer_name",
      "target": "customer_name",
      "type": "string",
      "required": true
    },
    {
      "source": "customer_phone",
      "target": "customer_phone",
      "type": "string",
      "required": true,
      "transform": "normalize_phone"
    },
    {
      "source": "address",
      "target": "delivery_address",
      "type": "string",
      "required": true
    },
    {
      "source": "weight",
      "target": "weight_kg",
      "type": "number",
      "required": true
    },
    {
      "source": "created_at",
      "target": "order_date",
      "type": "date",
      "required": true
    },
    {
      "source": "item_name",
      "target": "item_name",
      "type": "string",
      "required": false
    },
    {
      "source": "quantity",
      "target": "quantity",
      "type": "number",
      "required": false
    },
    {
      "source": "price",
      "target": "total_price",
      "type": "number",
      "required": false
    },
    {
      "source": "notes",
      "target": "notes",
      "type": "string",
      "required": false
    }
  ]
}
